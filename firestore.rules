rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: get current user's role
    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isAdmin()  { return userRole() == 'admin'; }
    function isMentor() { return userRole() == 'mentor'; }
    function isAuth()   { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }

    // Users collection
    match /users/{uid} {
      allow read:   if isAuth();
      allow create: if isAuth() && isOwner(uid);
      allow update: if isAuth() && (isOwner(uid) || isAdmin());
      allow delete: if isAdmin();
    }

    // Members collection
    match /members/{uid} {
      allow read:   if isAuth() && (isOwner(uid) || isAdmin() || isMentor());
      allow create: if isAuth();
      allow update: if isAuth() && (isOwner(uid) || isAdmin());
      allow delete: if isAdmin();
    }

    // Plans
    match /plans/{planId} {
      allow read:   if isAuth();
      allow write:  if isAdmin();
    }

    // Payments
    match /payments/{payId} {
      allow read:   if isAuth() && (
        isAdmin() ||
        resource.data.memberId == request.auth.uid
      );
      allow create: if isAuth();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Bookings
    match /bookings/{bookId} {
      allow read:   if isAuth() && (
        isAdmin() ||
        resource.data.memberId == request.auth.uid ||
        resource.data.mentorId == request.auth.uid
      );
      allow create: if isAuth();
      allow update: if isAuth() && (isAdmin() || resource.data.memberId == request.auth.uid || resource.data.mentorId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Progress
    match /progress/{progId} {
      allow read:   if isAuth() && (
        isAdmin() ||
        resource.data.memberId == request.auth.uid ||
        resource.data.mentorId == request.auth.uid
      );
      allow create: if isAuth() && isMentor();
      allow update: if isAuth() && (isMentor() || isAdmin());
      allow delete: if isAdmin();
    }
  }
}
