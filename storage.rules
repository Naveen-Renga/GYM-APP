rules_version = '2';

// ============================================================
// FIREBASE STORAGE RULES — IronForge Gym Management
// Copy these into Firebase Console > Storage > Rules
// ============================================================

service firebase.storage {
  match /b/{bucket}/o {

    // Profile images — users can read/write their own
    match /profiles/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024  // 5MB max
        && request.resource.contentType.matches('image/.*');
    }

    // Gym assets — anyone authenticated can read
    match /gym-assets/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false; // Only via Firebase console
    }
  }
}
